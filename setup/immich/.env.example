# Immich Environment Configuration
# Copy to .env and fill in real values before running setup.sh

# Upload storage path (inside containers)
UPLOAD_LOCATION=/usr/src/app/upload

# PostgreSQL credentials — change these before first run
DB_USERNAME=immich
DB_PASSWORD=CHANGE_ME
DB_DATABASE_NAME=immich

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME
